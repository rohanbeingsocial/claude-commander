{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Commander",
  "version": "0.1.0",
  "identifier": "com.rohan.claudecommander",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Commander",
        "width": 1400,
        "height": 880,
        "minWidth": 1060,
        "minHeight": 660
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
